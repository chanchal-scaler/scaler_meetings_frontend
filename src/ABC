import { useCallback, useMemo, useState } from 'react';
import FullWidget from '~meetings/widgets/full';
import Archive from './meetings/widgets/full/Archive';
import Live from './meetings/widgets/full/Live';
import Upcoming from './meetings/widgets/full/Upcoming';

function getSlugFromUrl() {
  const params = new URLSearchParams(window.location.search);
  return params.get('slug');
}

function App() {
  const slug = useMemo(() => getSlugFromUrl(), []);
  const [status, setStatus] = useState(null);

  const allowPreTestSetup = useCallback(() => {
    setStatus('ongoing');
  }, []);

  if (!slug) {
    return (
      <div style={{
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        height: '100vh',
        fontFamily: 'system-ui, sans-serif',
        color: '#555',
        flexDirection: 'column',
        gap: '12px',
      }}>
        <h2 style={{ margin: 0 }}>Scaler Meetings</h2>
        <p style={{ margin: 0 }}>
          Provide a meeting slug via <code>?slug=your-meeting-slug</code>
        </p>
      </div>
    );
  }

  return (
    <FullWidget
      slug={slug} 
      status={status}
      onTestSetupRequest={allowPreTestSetup}
      // headerLeftActions={headerLeftActions}
      // headerRightActions={headerRightActions}
      // onEndCallRequest={onEndCallRequest}
      // missingBookmarkActionRenderer={missingBookmarkActionRenderer}
      archiveComponent={Archive}
      liveComponent={Live}
      upcomingComponent={Upcoming}
    />
  );
}

export default App
